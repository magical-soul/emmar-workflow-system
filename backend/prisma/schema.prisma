datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
}

// The Company Workspace Scope
model Tenant {
  id          String             @id @default(uuid())
  name        String
  createdAt   DateTime           @default(now())
  memberships TenantMembership[]
  workflows   Workflow[]
  items       Item[]
}

// The Cross-Tenant Role Mapping Matrix
model TenantMembership {
  id       String @id @default(uuid())
  userId   String
  tenantId String
  role     String // 'ADMIN' | 'APPROVER' | 'USER'
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId]) // Enforces exactly ONE role per user inside a single tenant
  @@index([tenantId])
}

// The Immutable Workflow Template
model Workflow {
  id          String               @id @default(uuid())
  tenantId    String
  title       String
  version     Int                  @default(1)
  isActive    Boolean              @default(true)
  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  states      WorkflowState[]
  transitions WorkflowTransition[]
  items       Item[]

  @@unique([tenantId, title, version])
  @@index([tenantId])
}

// The Workflow Stages (e.g., DRAFT, PENDING_APPROVAL)
model WorkflowState {
  id         String   @id @default(uuid())
  workflowId String
  tenantId   String
  name       String   
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, name])
  @@index([tenantId])
}

// The Workflow Linking
model WorkflowTransition {
  id               String            @id @default(uuid())
  workflowId       String
  tenantId         String
  fromStateName    String
  toStateName      String
  requiresApproval Boolean           @default(false)
  approvalStrategy String            @default("SINGLE") // 'SINGLE' | 'MULTIPLE' | 'QUORUM'
  workflow         Workflow          @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  requests         ApprovalRequest[]

  @@index([workflowId, fromStateName, toStateName])
}

// The Transactional Business Asset Document Row
model Item {
  id           String            @id @default(uuid())
  tenantId     String
  workflowId   String
  currentState String            @default("DRAFT")
  title        String
  createdBy    String
  version      Int               @default(1)
  slaHours     Int               @default(48)
  escapedAt    DateTime?
  updatedAt    DateTime          @updatedAt        
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflow     Workflow          @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  requests     ApprovalRequest[]

  @@index([tenantId, currentState])
  @@index([workflowId])
}

// The Verification Hold Signature Request Ticket Queue
model ApprovalRequest {
  id                 String             @id @default(uuid())
  itemId             String
  transitionId       String
  tenantId           String
  assignedApproverId String
  delegatedToId      String?
  status             String             @default("PENDING") // 'PENDING' | 'APPROVED' | 'REJECTED'
  item               Item               @relation(fields: [itemId], references: [id], onDelete: Cascade)
  transition         WorkflowTransition @relation(fields: [transitionId], references: [id], onDelete: Cascade)

  @@index([tenantId, assignedApproverId, status]) // Accelerates Personalized Inbox fetching for managers
  @@index([itemId])                              // Speeds up parent asset resolution lookups
}

// The Time-Bound Authority Delegation Matrix
model ApprovalDelegations {
  id         String   @id @default(uuid())
  tenantId   String
  fromUserId String
  toUserId   String
  expiresAt  DateTime

  @@index([tenantId, toUserId, expiresAt]) // Eliminates query bottlenecks during delegation handshakes
}

// The Immutable History logger
model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  itemId      String?
  action      String   
  performedBy String
  payload     String  
  createdAt   DateTime @default(now())

  @@index([tenantId, itemId]) // Accelerates timeline rendering at the bottom of the UI
}
