{
  "name": "emaar-workflow-system",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "db:migrate": "npm run prisma:migrate --workspace=backend",
    "db:push": "npm run prisma:push --workspace=backend -- --force-reset",
    "db:seed": "npm run db:seed --workspace=backend",
    "db:studio": "npm run prisma:studio --workspace=backend",
    "dev:backend": "npm run dev --workspace=backend",
    "test:e2e": "npm run test:e2e --workspace=backend",
    "dev:frontend": "npm run dev -w frontend",
    "build:frontend": "npm run build -w frontend"
  }
}
